{
  "manifest_version": 3,
  "name": "SUAP - Coletor de Estagiários PRO",
  "version": "2.0.0",
  "description": "Coleta dados completos de estagiários do SUAP navegando automaticamente em cada perfil",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs",
    "background"
  ],
  "host_permissions": [
    "https://suap.ifro.edu.br/admin/estagios/praticaprofissional/*"
  ],
  "icons": {
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://suap.ifro.edu.br/admin/estagios/praticaprofissional/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
